{
  "name": "self-modifying-discord-bot",
  "version": "3.0.0",
  "description": "A self-modifying Discord bot with hot-reloading commands, optimized for VPS deployment",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "deploy": "node src/deploy-commands.js",
    "dev": "node --watch src/index.js"
  },
  "keywords": [
