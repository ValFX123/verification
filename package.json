    "bot",
    "self-modifying",
    "hot-reload",
    "vps"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@discordjs/core": "^2.4.0",
    "@discordjs/rest": "^2.6.1",
    "@discordjs/voice": "^0.18.0",
    "discord-api-types": "^0.38.42",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
